{
  "name": "homebridge-rainbird-local",
  "displayName": "Rain Bird",
  "type": "module",
  "version": "0.2.0",
  "description": "Local Rain Bird controller plugin with HTTPS fallback for 2.x firmware",
  "author": "chundla",
  "license": "MIT",
  "homepage": "https://github.com/chundla/homebridge-rainbird-local#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/chundla/homebridge-rainbird-local.git"
  },
  "bugs": {
    "url": "https://github.com/chundla/homebridge-rainbird-local/issues"
  },
  "keywords": [
    "homebridge-plugin",
    "rainbird",
    "HomeKit",
    "irrigation"
  ],
  "main": "dist/index.js",
  "engines": {
    "node": ">=20.18.0",
    "homebridge": "^1.8.0 || ^2.0.0-beta.0"
  },
  "scripts": {
    "build": "rimraf ./dist && tsc && cp -R src/resources dist/resources",
    "lint": "eslint . --max-warnings=0",
    "prepublishOnly": "npm run lint && npm run build",
    "test": "npm run build && node --test test/**/*.test.js",
    "watch": "npm run build && npm link && nodemon"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "config.schema.json"
  ],
  "dependencies": {
    "homebridge-lib": "^7.3.2",
    "undici": "^6.25.0",
    "yaml": "^2.9.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/node": "^24.12.4",
    "eslint": "^9.39.4",
    "homebridge": "^2.0.2",
    "nodemon": "^3.1.11",
    "rimraf": "^6.1.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.59.3"
  }
}
