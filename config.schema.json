{
  "pluginAlias": "RainBirdLocal",
  "pluginType": "platform",
  "singular": true,
  "schema": {
    "type": "object",
    "properties": {
      "name": {
        "title": "Plugin Name",
        "type": "string",
        "default": "Rain Bird"
      },
      "debug": {
        "title": "Verbose Debug Logging",
        "type": "boolean",
        "default": false,
        "description": "Plugin-level debug logging and Rain Bird request/response traces."
      },
      "devices": {
        "title": "Devices",
        "type": "array",
        "description": "One or more Rain Bird controllers.",
        "items": {
          "type": "object",
          "properties": {
            "configDevice": {
              "title": "Device Name",
              "type": "string",
              "description": "Name shown in Homebridge/HomeKit for this controller."
            },
            "host": { "title": "Controller IP/Host", "type": "string" },
            "password": { "title": "Controller Password", "type": "string", "format": "password" },
            "expose": { "title": "Expose Mode", "type": "string", "enum": ["controller", "zones"], "default": "controller" },
            "zoneNames": { "title": "Zone Names", "type": "array", "items": { "type": "string" } },
            "ignoredZones": { "title": "Ignored Zones", "type": "array", "items": { "type": "integer", "minimum": 1 } },
            "defaultDurationMinutes": { "title": "Default Zone Duration (minutes)", "type": "integer", "default": 10, "minimum": 1, "maximum": 240 },
            "refreshIntervalSeconds": { "title": "Refresh Interval (seconds)", "type": "integer", "default": 30, "minimum": 10, "maximum": 300 },
            "programSwitches": { "title": "Enable Program Switches", "type": "boolean", "default": false },
            "programSwitchList": {
              "title": "Program Switch List (A=1, B=2, C=3, D=4)",
              "type": "array",
              "items": { "type": "integer", "enum": [1, 2, 3, 4] }
            },
            "zoneSwitches": { "title": "Expose Zone Switches", "type": "boolean", "default": true },
            "zoneValves": { "title": "Expose Zone Valves", "type": "boolean", "default": true },
            "logScheduleOnStart": { "title": "Log Schedule on Start", "type": "boolean", "default": false }
          },
          "required": ["host", "password"]
        }
      }
    },
    "required": []
  }
}
